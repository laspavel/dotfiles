BYellow="\[\033[1;33m\]"; BBlue="\[\033[1;34m\]";   BMagenta="\[\033[1;35m\]"
BCyan="\[\033[1;36m\]";   BWhite="\[\033[1;37m\]"

UBlack="\[\033[4;30m\]";  URed="\[\033[4;31m\]";    UGreen="\[\033[4;32m\]"
UYellow="\[\033[4;33m\]"; UBlue="\[\033[4;34m\]";   UMagenta="\[\033[4;35m\]"
UCyan="\[\033[4;36m\]";   UWhite="\[\033[4;37m\]"

On_Black="\[\033[40m\]";  On_Red="\[\033[41m\]";    On_Green="\[\033[42m\]"
On_Yellow="\[\033[43m\]"; On_Blue="\[\033[44m\]";   On_Magenta="\[\033[45m\]"
On_Cyan="\[\033[46m\]";   On_White="\[\033[47m\]"

IBlack="\[\033[0;90m\]";  IRed="\[\033[0;91m\]";    IGreen="\[\033[0;92m\]"
IYellow="\[\033[0;93m\]"; IBlue="\[\033[0;94m\]";   IMagenta="\[\033[0;95m\]"
ICyan="\[\033[0;96m\]";   IWhite="\[\033[0;97m\]"

BIBlack="\[\033[1;90m\]"; BIRed="\[\033[1;91m\]";   BIGreen="\[\033[1;92m\]"
BIYellow="\[\033[1;93m\]";BIBlue="\[\033[1;94m\]";  BIMagenta="\[\033[1;95m\]"
BICyan="\[\033[1;96m\]";  BIWhite="\[\033[1;97m\]"

On_IBlack="\[\033[0;100m\]"; On_IRed="\[\033[0;101m\]";  On_IGreen="\[\033[0;102m\]"
On_IYellow="\[\033[0;103m\]";On_IBlue="\[\033[0;104m\]"; On_IMagenta="\[\033[0;105m\]"
On_ICyan="\[\033[0;106m\]";  On_IWhite="\[\033[0;107m\]"

if [[ -n "${SSH_CLIENT:-}${SSH_TTY:-}" ]]; then
  PS1="$BRed[SSH]$Color_Off $BBlue\u@\h:$BRed\$(parse_git_branch)$Color_Off$BGreen\w$ $Color_Off"
else
  PS1="$BBlue\u@\h:$BRed\$(parse_git_branch)$Color_Off$BGreen\w$ $Color_Off"
fi

# =================== ALIASES =============================================

if command -v grc >/dev/null; then
  for _cmd in cvs diff esperanto gcc irclog ldap log netstat ping proftpd traceroute wdiff; do
    alias "$_cmd"="grc --colour=auto $_cmd"
  done
  unset _cmd
fi

if command -v gls >/dev/null; then
  alias ls='gls --color=auto'
fi

alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
alias ..='cd ../'
alias ...='cd ../..'
alias f='file'
alias s='stat'
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'
alias n='nano'
alias vi='vim'
alias v='$EDITOR'
alias e='$EDITOR'
alias cls='clear'
alias r='reset'
alias df='df -h'
alias du='du -h'
alias h='history'
alias mkdir='mkdir -pv'
alias listen="lsof -P -i -n"
alias now='date +%d.%m.%Y%n%T'
alias week='date +%V'
alias reload="exec ${SHELL} -l"
alias psmem10="ps auxf | sort -nr -k 4 | head -10"
alias pscpu10="ps auxf | sort -nr -k 3 | head -10"
alias most10='du -hsx * | sort -rh | head -10'
alias dud="du -d 1"
alias weather="curl wttr.in/Dnepr"
alias port='ss -tulanp 2>/dev/null || netstat -tulan'
alias py3='docker run -it --rm --hostname py3 -v $(pwd):/data -w /data python:3.9 /bin/bash'
alias m='mount'
alias ?='calcc'

# Platform-specific aliases
if command -v fusermount >/dev/null; then alias u='fusermount -u -z'; fi
if command -v free       >/dev/null; then alias free='free -h'; fi

if command -v mc >/dev/null 2>&1; then
    alias mc='mc -x'
fi

# =================== EXPORTS =============================================

export EDITOR="vim"
# export TMPDIR="${HOME}/tmp" && mkdir -p "$TMPDIR"
export MANPAGER="less -X"
export PAGER="less"
export LESS="-M -n -q -i -r"

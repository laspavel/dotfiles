# =================== PROMPT COMMAND =====================================

_prompt_history() {
  history -a; 
  history -n
}
case ";${PROMPT_COMMAND:-};" in
  *";_prompt_history;"*) ;;
  *) PROMPT_COMMAND="_prompt_history${PROMPT_COMMAND:+; $PROMPT_COMMAND}" ;;
esac

# =================== AUTOCOMPLETE =======================================

if [ -d "$HOME/.local/.bash.autocomplete.d" ]; then
  shopt -s nullglob
  for src in "$HOME/.local/.bash.autocomplete.d/"*; do . "$src"; done
  shopt -u nullglob
fi

if command -v terraform >/dev/null 2>&1; then complete -C terraform terraform; fi
if command -v vault     >/dev/null 2>&1; then complete -C vault vault; fi

# =================== KUBERNETES =========================================
_kubeconfigs=""

if [ -d "$HOME/.kube/clusters" ]; then
  _kubeconfigs="$(find "$HOME/.kube/clusters" -maxdepth 1 -type f 2>/dev/null | paste -sd ':' -)"
elif [ -d "$HOME/.kube" ]; then
  _kubeconfigs="$(find -L "$HOME/.kube" -type f \( -name 'config' -o -name '*.yml' -o -name '*.yaml' \) 2>/dev/null | paste -sd ':' -)"
fi

if [ -n "$_kubeconfigs" ]; then
  export KUBECONFIG="$_kubeconfigs"
fi

unset _kubeconfigs

if command -v kubectl >/dev/null 2>&1; then
  alias k="kubectl"
  source <(kubectl completion bash) 2>/dev/null

  if declare -F __start_kubectl >/dev/null 2>&1; then
    complete -F __start_kubectl kubectl
    complete -o default -F __start_kubectl k
  fi
fi

kx() {
  command -v kubectl >/dev/null 2>&1 || { echo "kubectl not found" >&2; return 127; }

  if [ $# -eq 0 ]; then
    kubectl config get-contexts
    return 0
  fi

  if kubectl config get-contexts -o name 2>/dev/null | grep -Fxq -- "$1"; then
    kubectl config use-context "$1"
    return 0
  fi

  kubectl "$@"
}

_kx_autocomplete() {
  command -v kubectl >/dev/null 2>&1 || return 0
  local cur="${COMP_WORDS[COMP_CWORD]}"
  COMPREPLY=($(compgen -W "$(kubectl config get-contexts -o name 2>/dev/null)" -- "$cur"))
}
complete -F _kx_autocomplete kx

kn() {
  command -v kubectl >/dev/null 2>&1 || { echo "kubectl not found" >&2; return 127; }

  if [ $# -eq 0 ]; then
    kubectl get namespaces
    local current_ns
    current_ns=$(kubectl config view --minify --output 'jsonpath={..namespace}' 2>/dev/null)
    echo -e "\nCurrent namespace: ${current_ns:-default}\n"
    return 0
  fi

  if kubectl get namespace "$1" --request-timeout=3s >/dev/null 2>&1; then
    kubectl config set-context --current --namespace="$1"
    echo "Switched to namespace: $1"
    return 0
  fi

  kubectl "$@"
}

_kn_autocomplete() {
  command -v kubectl >/dev/null 2>&1 || return 0
  local cur="${COMP_WORDS[COMP_CWORD]}"
  local ns
  ns="$(kubectl get namespaces --request-timeout=2s -o jsonpath='{.items[*].metadata.name}' 2>/dev/null)"
  COMPREPLY=($(compgen -W "$ns" -- "$cur"))
}
complete -F _kn_autocomplete kn


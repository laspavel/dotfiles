# ########################### MY CONFIGURATION ###########################

# Apply: source $HOME/.laspavelrc

# =================== CORE (always, before interactive check) =============

if [ -z "${HOME:-}" ]; then
  export HOME=~
fi

# Locale 
if [[ -z "${LANG}" ]]; then
  export LANG="uk_UA.UTF-8"
fi
export LC_COLLATE="C"
unset LC_ALL
unset LC_CTYPE

# PATH — только если не установлен
if ! [[ "$PATH" =~ "/opt/homebrew/bin:$HOME/.local/bin:$HOME/bin:$HOME/.krew/bin:" ]]; then
  PATH="/opt/homebrew/bin:$HOME/.local/bin:$HOME/bin:$HOME/.krew/bin:$PATH"
fi

# Скрипты — добавляем все поддиректории
if [ -d "$HOME/.local/scripts" ]; then
  export PATH="$PATH:$(find "$HOME/.local/scripts" -type d 2>/dev/null | paste -sd ':' -)"
fi

# Apple Terminal locale integration (macOS only)
[[ -r /etc/bashrc_Apple_Terminal ]] && . /etc/bashrc_Apple_Terminal

# Только для интерактивных сессий
if [[ $- != *i* ]]; then
  return 0 2>/dev/null || exit 0
fi

# =================== COMPLETION ==========================================

if [ -f /opt/homebrew/etc/profile.d/bash_completion.sh ]; then
  . /opt/homebrew/etc/profile.d/bash_completion.sh
fi

# =================== FUNCTIONS ===========================================

# Hash string. Does not override system md5 command.
md5str() {
  if [ $# -eq 0 ]; then
    echo "usage: md5str <string>" >&2
    return 2
  fi

  if command -v md5sum >/dev/null 2>&1; then
    printf '%s' "$1" | md5sum | awk '{print $1}'
  else
    printf '%s' "$1" | command md5 -q
  fi
}

# Hash file. Does not override system md5 command.
md5file() {
  if [ $# -eq 0 ]; then
    echo "usage: md5file <file>" >&2
    return 2
  fi

  if [ ! -f "$1" ]; then
    echo "md5file: file not found: $1" >&2
    return 1
  fi

  if command -v md5sum >/dev/null 2>&1; then
    md5sum "$1" | awk '{print $1}'
  else
    command md5 -q "$1"
  fi
}

ipinfo() {
  command -v curl >/dev/null 2>&1 || { echo "curl not found" >&2; return 127; }
  curl -fsSL "https://ip.guide/${1}"
  echo ""
}

ipinfo2() {
  command -v curl >/dev/null 2>&1 || { echo "curl not found" >&2; return 127; }
  curl -fsS "https://ifconfig.co/json${1:+?ip=$1}"
  echo ""
}

calcc() { 
  awk "BEGIN{ print $* }"; 
}

www() {
  command -v watch >/dev/null 2>&1 || { echo "watch not found" >&2; return 127; }
  watch -tn 1 "$@"
}

dnsinfo() {
  command -v dig >/dev/null 2>&1 || { echo "dig not found. Install bind-utils/dnsutils." >&2; return 127; }
  dig "$1" @resolver1.opendns.com
}

flushdns() {
  if command -v resolvectl >/dev/null 2>&1; then
    sudo resolvectl flush-caches
  else
    sudo dscacheutil -flushcache && sudo killall -HUP mDNSResponder
  fi
}

urldecode() {
  local py
  py=$(command -v python3 || command -v python)
  if [ -n "$py" ]; then
    "$py" -c "import sys, urllib.parse; print(urllib.parse.unquote_plus(sys.argv[1]))" "$1"
  else
    echo "urldecode: python not found" >&2
    return 1
  fi
}

# parse_git_branch() {
#   git branch 2>/dev/null | sed -n '/\* /s///p' | sed 's/.*/(&)/'
# }

parse_git_branch() {
  local branch
  branch="$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD 2>/dev/null)" || return 0
  printf '(%s)' "$branch"
}

ssh() {
  if [[ -n "${TMUX:-}" ]] && command -v tmux >/dev/null 2>&1; then
    local old_name rc target
    old_name="$(tmux display-message -p '#W' 2>/dev/null)"
    target="$1"

    [ -n "$target" ] && tmux rename-window "ssh:${target}" 2>/dev/null

    command ssh "$@"
    rc=$?

    [ -n "$old_name" ] && tmux rename-window "$old_name" 2>/dev/null

    return "$rc"
  fi

  command ssh "$@"
}

man() {
  env \
    LESS_TERMCAP_mb="$(printf '\e[1;31m')" \
    LESS_TERMCAP_md="$(printf '\e[1;31m')" \
    LESS_TERMCAP_me="$(printf '\e[0m')"    \
    LESS_TERMCAP_se="$(printf '\e[0m')"    \
    LESS_TERMCAP_so="$(printf '\e[1;44;33m')" \
    LESS_TERMCAP_ue="$(printf '\e[0m')"    \
    LESS_TERMCAP_us="$(printf '\e[1;32m')" \
    command man "$@"
}

tt() {
  command -v tmux >/dev/null 2>&1 || { echo "tmux not found" >&2; return 127; }
  local session_name="${TMUX_SESSION_NAME:-default1}"
  if tmux has-session -t "$session_name" 2>/dev/null; then
    tmux attach-session -t "$session_name"
  else
    tmux new-session -s "$session_name"
  fi
}

# =================== SHELL OPTIONS =======================================

if [ -z "${TERM:-}" ] || [ "$TERM" = "dumb" ]; then
  export TERM="xterm-256color"
fi

[ "${BASH_VERSINFO[0]}" -ge 4 ] && shopt -s autocd  2>/dev/null
shopt -s histappend
shopt -s checkwinsize
shopt -s cdspell
shopt -s dirspell 2>/dev/null
shopt -s cmdhist

